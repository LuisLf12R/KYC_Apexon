# ============================================================
# KYC APEXON — Environment Variables Template
# ============================================================
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual API keys in .env
#   3. NEVER commit .env to Git
# ============================================================

# Anthropic / Claude API Key
# Get it at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Google Vision API - Local Development
# For local testing, download google-vision-sa-checkpoint.json and point to it:
GOOGLE_APPLICATION_CREDENTIALS=./google-vision-sa-checkpoint.json

# For Railway, credentials are injected via Dockerfile build arg:
# GOOGLE_CREDENTIALS_JSON=[Railway Secret only]

# Streamlit (optional, defaults are usually fine)
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_HEADLESS=true
