# ============================================================
# KYC APEXON — Environment Variables Template
# ============================================================
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual API keys in .env
#   3. NEVER commit .env to Git
# ============================================================

# Anthropic / Claude API Key
# Get it at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Google Vision — Option A: Local path to JSON file (for local dev)
# GOOGLE_VISION_JSON_PATH=/full/path/to/service-account.json

# Google Vision — Option B: Base64-encoded JSON (for Vercel/cloud deployment)
# GOOGLE_VISION_JSON_BASE64=eyJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsIC4uLn0=

# Streamlit (optional, defaults are usually fine)
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_HEADLESS=true
