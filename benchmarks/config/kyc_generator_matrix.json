{
  "axes": {
    "customer_type": {
      "allowed_values": ["INDIVIDUAL", "LEGAL_ENTITY"],
      "must_cover": true
    },
    "risk_tier": {
      "allowed_values": ["LOW", "MEDIUM", "HIGH"],
      "must_cover": true
    },
    "aml_state": {
      "allowed_values": [
        "NO_HIT_CURRENT",
        "NO_HIT_OVERDUE",
        "HIT_UNDER_REVIEW",
        "FALSE_POSITIVE_RESOLVED",
        "BLOCKED",
        "NO_SCREENING"
      ],
      "must_cover": true
    }
  },
  "portfolio_targets": {
    "min_size": 25,
    "max_size": 40,
    "decision_shares": {
      "PASS": [0.4, 0.5],
      "REVIEW": [0.3, 0.4],
      "REJECT": [0.15, 0.25]
    }
  }
}
