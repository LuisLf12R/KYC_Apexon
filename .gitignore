# ============================================================
# KYC APEXON — .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
**/.ipynb_checkpoints/
*.ipynb_checkpoints

# Secrets & Credentials — NEVER commit these
.env
.env.local
.env.*
!.env.example
google-vision-sa-checkpoint.json
/tmp/google-credentials.json
Credentials/
*.json
*.pem
*.key
base64_key.txt
service-account*.json
*-sa.json
*-sa*.json

# Data files — use cloud storage or DVC instead
Data Raw/
Data Clean/
Output/
*.csv
*.xlsx
*.xls

# Images
Images for OCR/

# User data
users.json

# Temporary / Testing
*.tmp
temp/
test_output/
batch_results*.csv
debug_*.log

# Pytest
.pytest_cache/
.coverage
htmlcov/
