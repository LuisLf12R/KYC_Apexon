  "score_thresholds": {
    "pass_minimum": 70,
    "pass_with_notes_minimum": 50,
    "note": "Thresholds apply only when no Reject or Review triggers are hit. Score shown on all dispositions for context."
  },
  "disposition_levels": {
    "PASS": {
      "description": "Customer meets all KYC requirements. No hard-reject or review triggers fired. Score at or above pass_minimum.",
      "color": "green",
      "requires_human_action": false,
      "can_be_cleared_by": null
    },
    "PASS_WITH_NOTES": {
      "description": "Customer meets minimum KYC requirements but one or more advisory findings were recorded. Score between pass_with_notes_minimum and pass_minimum.",
      "color": "yellow",
      "requires_human_action": false,
      "can_be_cleared_by": null
    },
    "REVIEW": {
      "description": "One or more review rules triggered. Compliance analyst must clear the case before onboarding can proceed.",
      "color": "orange",
      "requires_human_action": true,
      "can_be_cleared_by": "compliance_analyst"
    },
    "REJECT": {
      "description": "One or more hard-reject rules triggered. Onboarding is prohibited. No score threshold can override.",
      "color": "red",
      "requires_human_action": true,
      "can_be_cleared_by": "senior_compliance_officer"
    }
  },
  "dimension_parameters": {
    "identity": {
      "min_verified_docs": 1,
      "doc_expiry_warning_days": 90,
      "accepted_doc_types": [
        "passport",
        "national_id",
        "driving_licence",
        "residence_permit"
      ]
    },
    "screening": {
      "max_screening_age_days": 365,
      "fuzzy_match_threshold": 0.85
    },
    "beneficial_ownership": {
      "ownership_threshold_pct": 25.0,
      "max_chain_depth": 4
    },
    "transactions": {
      "edd_trigger_threshold_usd": 10000.0,
      "velocity_window_days": 90
    },
    "documents": {
      "max_doc_age_days": 90,
