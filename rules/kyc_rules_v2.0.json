        "effective_until": null,
        "regulatory_refs": [
          "FATF Rec 10 \u2014 Customer Due Diligence",
          "Wolfsberg Private Banking Principles 2012 s.2.1"
        ]
      }
    },
    {
      "rule_id": "HR-004",
      "name": "No Screening Record",
      "description": "No AML screening record exists for this customer. Screening is mandatory before onboarding.",
      "dimension": "aml_screening",
      "condition_field": "status",
      "condition_value": "no_screening_record",
