    {
      "rule_id": "RV-005",
      "name": "Beneficial Ownership Below Minimum Data Quality",
      "description": "Beneficial ownership data is present but critically incomplete. UBO cannot be confirmed.",
      "dimension": "beneficial_ownership",
      "condition_field": "status",
      "condition_value": "insufficient_ubo_data",
      "policy_reference": "KYC Policy 3.1 — Beneficial Ownership Minimum Standard",
      "provenance": {
        "regulator": "FinCEN",
        "jurisdiction": "USA",
        "source_url": "https://www.ecfr.gov/current/title-31/subtitle-B/chapter-X/part-1010/subpart-B/section-1010.230",
        "snapshot_hash": null,
        "published_at": "2016-05-11",
