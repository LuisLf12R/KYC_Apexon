{
  "version": "kyc-rules-v2.0",
  "effective_date": "2026-01-01",
  "description": "PWM jurisdiction-aware KYC ruleset v2.0. Baseline: FATF Recommendations and Wolfsberg Private Banking Principles. Jurisdiction overlays for USA, GBR, EU, CHE, SGP, HKG, AUS. China deferred post-v1.",
  "created_by": "hand-authored",
  "changelog": [
    {
      "version": "kyc-rules-v2.0",
      "date": "2026-04-19",
      "change": "Phase 3: jurisdiction-aware ruleset. Baseline lifted from v1.1. Eight jurisdiction overlays added: USA, GBR, EU, CHE, SGP, HKG, AUS. HKG SFC 10% UBO threshold, SGP MAS 30-day velocity window, EU/CHE 180-day rescreening interval, GBR 60-day doc expiry warning. China deferred post-v1.",
      "author": "hand-authored",
      "reviewed_by": null
    },
    {
      "version": "kyc-rules-v1.1",
      "date": "2026-01-01",
      "change": "Phase 1/2: added dimension_parameters block, provenance on all rules, corrected data_quality critical_fields to match actual CSV schema.",
      "author": "hand-authored",
      "reviewed_by": null
    }
  ],
  "hard_reject_rules": [
    {
      "rule_id": "HR-001",
      "name": "Confirmed Sanctions Match",
      "description": "Customer has a confirmed match on an active sanctions list. Onboarding is prohibited.",
      "dimension": "aml_screening",
      "condition_field": "status",
      "condition_value": "confirmed_match",
      "policy_reference": "AML Policy 4.1 \u2014 Sanctions Zero Tolerance",
      "provenance": {
        "regulator": "FATF",
        "jurisdiction": "supranational",
        "source_url": "https://www.fatf-gafi.org/content/dam/fatf-gafi/recommendations/FATF%20Recommendations%202012.pdf",
        "snapshot_hash": null,
        "published_at": "2012-02-16",
        "effective_from": "2012-02-16",
        "effective_until": null,
        "regulatory_refs": [
          "FATF Rec 6 \u2014 Targeted Financial Sanctions",
          "FATF Rec 7 \u2014 Proliferation Financing Sanctions",
          "Wolfsberg Private Banking Principles 2012 s.4"
        ]
      }
    },
    {
      "rule_id": "HR-002",
      "name": "High-Risk Jurisdiction \u2014 Unmitigated",
      "description": "Customer is domiciled in or transacts through a FATF black-listed or grey-listed jurisdiction with no documented EDD mitigation.",
      "dimension": "aml_screening",
      "condition_field": "status",
      "condition_value": "high_risk_jurisdiction_unmitigated",
      "policy_reference": "AML Policy 5.1 \u2014 High-Risk Jurisdiction Controls",
      "provenance": {
        "regulator": "FATF",
        "jurisdiction": "supranational",
        "source_url": "https://www.fatf-gafi.org/content/dam/fatf-gafi/recommendations/FATF%20Recommendations%202012.pdf",
        "snapshot_hash": null,
        "published_at": "2012-02-16",
        "effective_from": "2012-02-16",
        "effective_until": null,
        "regulatory_refs": [
          "FATF Rec 19 \u2014 Higher-Risk Countries",
          "FATF INR 19 \u2014 Enhanced Due Diligence for High-Risk Countries"
        ]
      }
    },
    {
      "rule_id": "HR-003",
      "name": "Identity Cannot Be Established",
      "description": "All submitted identity verification attempts have been rejected. Identity cannot be established.",
      "dimension": "identity_verification",
      "condition_field": "status",
      "condition_value": "all_rejected",
      "policy_reference": "KYC Policy 2.1 \u2014 Identity Verification Minimum Standard",
      "provenance": {
        "regulator": "FATF",
        "jurisdiction": "supranational",
        "source_url": "https://www.fatf-gafi.org/content/dam/fatf-gafi/recommendations/FATF%20Recommendations%202012.pdf",
