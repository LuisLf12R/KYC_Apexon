      }
    },
    {
      "rule_id": "RV-006",
      "name": "Critical Data Quality Failure",
      "description": "Core customer record fields are missing or corrupt. Record integrity is in question.",
      "dimension": "data_quality",
      "condition_field": "quality_rating",
